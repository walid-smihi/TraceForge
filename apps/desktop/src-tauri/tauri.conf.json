{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TraceForge",
  "version": "0.1.0",
  "identifier": "com.traceforge.desktop",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": {
      "script": "npm run dev:desktop",
      "cwd": "../../web"
    },
    "beforeBuildCommand": {
      "script": "npm run build:desktop",
      "cwd": "../../web"
    }
  },
  "app": {
    "windows": [
      {
        "title": "TraceForge",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/traceforge-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
