# Database — SQLite file under STORAGE_PATH, no external DB service needed
DATABASE_URL=sqlite+aiosqlite:////app/storage/traceforge.db

# File storage
STORAGE_PATH=/app/storage

# Security (reserved for V2 auth)
JWT_SECRET=change-this-in-production-min-32-chars

# LLM — default: Ollama local ($0 cost)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM — cloud optional (user's own keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_MB=50
